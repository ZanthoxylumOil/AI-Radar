# OpenAI-compatible API. Leave API_KEY empty to use the built-in rule engine.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT=60

DATABASE_PATH=data/ai_radar.db
REPORT_DIR=reports
MAX_ITEMS_PER_SOURCE=20
LOOKBACK_HOURS=72
REQUEST_TIMEOUT=20
FLASK_HOST=0.0.0.0
FLASK_PORT=8000